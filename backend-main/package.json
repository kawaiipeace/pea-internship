{
  "name": "backend",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "PORT=2702 bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "paths": {
    "@/*": [
      "./src/*"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "better-auth": "^1.5.4",
    "cron": "^4.4.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "elysia-logger": "^0.5.2",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.9"
  },
  "module": "src/index.js"
}
