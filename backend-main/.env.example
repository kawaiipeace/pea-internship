# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intern-pea

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-generate-a-strong-one
BETTER_AUTH_BASE_URL=http://localhost:2702

# Keycloak Configuration (Optional - for OAuth/OIDC)
KEYCLOAK_CLIENT_ID=your-keycloak-client-id
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
KEYCLOAK_DISCOVERY_URL=https://your-keycloak-server/realms/your-realm/.well-known/openid-configuration

# AWS S3 / MinIO Configuration (for file uploads)
AWS_REGION=us-east-1
MINIO_ENDPOINT=http://localhost:2704
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=intern-pea
MINIO_PUBLIC_ENDPOINT=http://localhost:2704

# Server Configuration
PORT=2702
NODE_ENV=production
